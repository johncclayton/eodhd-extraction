# Copy this file to .env and add your real token.  NEVER CHECK THE .env FILE INTO SOURCE CONTROL.
EODHD_API_TOKEN=your-token-here

# Optional: override eodhd-config.json (same logical names; also accepted as EODHD_<SNAKE> or <SNAKE>).
# Precedence: JSON file, then .env, then process environment.
# EODHD_OUTPUT_DIRECTORY=./output
# EODHD_LOGS_DIRECTORY=./logs
# EODHD_SYMBOL_FORMAT={Code}.{ExchangeCode}
# EODHD_REQUEST_TIMEOUT_SECONDS=90
# Comma-separated or JSON array:
# EODHD_CURRENCIES=EUR,CHF
# EODHD_COUNTRIES=["DE","CH"]
# exchanges must be JSON matching the config file shape:
# EODHD_EXCHANGES=[{"code":["XETRA","SW"]}]
